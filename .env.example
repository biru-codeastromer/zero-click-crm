## Zero-Click CRM (Next.js + GCP)
#
# Copy to `.env.local` for local development.
#
# Never commit real credentials. Prefer `GOOGLE_APPLICATION_CREDENTIALS_JSON`
# (a service account JSON string) for deployments where you can store secrets.

# GCP Project
GCP_PROJECT_ID="gen-lang-client-0419608159"

# Google Cloud Storage
GCS_UPLOAD_BUCKET="zero-click-uploads-gen-lang-client-0419608159"

# BigQuery
BQ_LOCATION="asia-south1"
BQ_DATASET="zero_click_crm_dataset"
BQ_TABLE="contacts"

# Vertex AI (used by /api/search)
VERTEX_LOCATION="us-central1"
VERTEX_MODEL="gemini-2.5-flash"

# Credentials (choose one)
#
# Option A (recommended): raw JSON string
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
#
# Option B: path to a local JSON file (local dev only)
GOOGLE_APPLICATION_CREDENTIALS=""
